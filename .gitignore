# --- Large/generated model + experiment artifacts (weights, states, checkpoints) ---
# dir-level so git never recurses into the >1TB of data
Qwen*/
converted*/
engram*/
mem_targets/
runs/
research/
# weight/state blobs anywhere (lenses, plans, patches, ckpts)
*.pt
*.pth
*.ckpt
*.safetensors
*.bin
*.gguf
*.onnx

# --- Dashboards: SQLite DBs + compiled binaries (the Go/JS *source* is tracked) ---
*.db
*.db-wal
*.db-shm
# compiled Go binaries (built from ./cmd/trainboard); source stays tracked
dashboard/trainboard
dashboard/trainboard-candidate*
dashboard/launches/

# --- Logs and local process metadata ---
*.log
.supervisor_child_*

# --- Retired v1 code (kept locally, not part of the public repo) ---
legacy/

# --- Editor / OS cruft ---
*.swp
*.tmp
.DS_Store
experiments.db
models/cache/

# --- Local multimodal corpora, generated manifests, and model trees ---
# These directories contain multi-GB/TB downloads, extracted images, local
# absolute paths, generated review packs, and third-party dataset metadata.
/datasets/
/models/
/curated_vision/
/NSFW_Manga/
/i1-captions/
/joy-captioning-*/
/nsfw-video-still-caption-grid-only/
